# ══════════════════════════════════════════════════════════════════════════════
# Incident Mesh — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ══════════════════════════════════════════════════════════════════════════════

# ── LLM API ───────────────────────────────────────────────────────────────────
# Get your key from https://fireworks.ai
FIREWORKS_API_KEY=your_fireworks_api_key_here

# ── Models ────────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
JUDGE_MODEL=accounts/fireworks/models/mixtral-8x7b-instruct
AGENT_MODEL=accounts/fireworks/models/llama-v3-8b-instruct

# ── Redis ─────────────────────────────────────────────────────────────────────
# Do NOT change this — it must match the service name in docker-compose.yml
REDIS_URL=redis://redis:6379

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Change these to strong values before deploying to production!
POSTGRES_USER=incident_mesh
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=incident_mesh

# ── JWT Authentication ────────────────────────────────────────────────────────
# MUST be a long random secret. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_64_char_random_hex_string
